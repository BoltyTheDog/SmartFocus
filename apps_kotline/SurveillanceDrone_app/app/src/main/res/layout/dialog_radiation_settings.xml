<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_dialog_rounded">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Visualization Settings"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- Lower Bound -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lower Bound"
        android:textColor="#DDDDDD"
        android:textSize="14sp"/>
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        
        <SeekBar
            android:id="@+id/seek_lower"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="255"
            android:progress="0"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF"/>
            
        <TextView
            android:id="@+id/text_lower_value"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:gravity="end"
            android:textStyle="bold"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Upper Bound -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upper Bound"
        android:textColor="#DDDDDD"
        android:textSize="14sp"/>
        
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        
        <SeekBar
            android:id="@+id/seek_upper"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="255"
            android:progress="255"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF"/>
            
        <TextView
            android:id="@+id/text_upper_value"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="255"
            android:textColor="#FFFFFF"
            android:gravity="end"
            android:textStyle="bold"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Time Resolution -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Time Resolution"
        android:textColor="#DDDDDD"
        android:textSize="14sp"/>
        
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        
        <SeekBar
            android:id="@+id/seek_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF"/>
            
        <TextView
            android:id="@+id/text_time_value"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="20s"
            android:textColor="#FFFFFF"
            android:gravity="end"
            android:textStyle="bold"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Channel Range (Zoom) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Channel Range (Zoom)"
        android:textColor="#DDDDDD"
        android:textSize="14sp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/text_channel_start"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:gravity="end"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"/>
        
        <com.google.android.material.slider.RangeSlider
            android:id="@+id/range_channel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="0.0"
            android:valueTo="2048.0"
            android:stepSize="1.0"
            app:thumbColor="#FFFFFF"
            app:trackColorActive="#FFFFFF"
            app:trackColorInactive="#424242"
            app:tickColorActive="#FFFFFF"
            app:tickColorInactive="#424242"
            app:haloColor="#40FFFFFF"/>

        <TextView
            android:id="@+id/text_channel_end"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="2048"
            android:textColor="#FFFFFF"
            android:gravity="start"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="24dp"/>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        
        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="#FFFFFF"
            android:backgroundTint="#424242"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_ok"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="OK"
            android:textColor="#333333"
            android:backgroundTint="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>
